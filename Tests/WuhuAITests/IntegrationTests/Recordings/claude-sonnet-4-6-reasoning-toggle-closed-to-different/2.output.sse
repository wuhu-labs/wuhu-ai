data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":"You"}           }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" know how a regular computer is like a light switch — it's either **on or"}}

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" off**, right? Well, a quantum computer is like a *magic* light switch that can be **both on AND"}              }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" off at the same time** — until you look at it, and then it picks one"}       }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":"!\n\nThis might sound silly, but it actually helps the"}  }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" computer try **lots of answers all at once** instead of trying them"}               }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" one at a time. Imagine you're trying to find your toy in a big pile —"}             }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" a normal computer checks each toy one by one, but a quantum computer can check **all of"}    }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" them at the same time!**\n\nThis makes it really, really good"}     }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" at solving super hard puzzles much faster than a regular computer. Scientists"}            }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" are still working on making these computers bigger and better, because right now they're a"}        }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":" little tricky to build — kind of like trying to build with **"}               }

event: content_block_delta
data: {"type":"content_block_delta","index":0,"delta":{"type":"text_delta","text":"very, very wobbly blocks!** 🧱"}             }

