data: {"candidates": [{"content": {"parts": [{"text": " is a revolutionary paradigm of calculation that leverages the principles of quantum mechanics, such as superposition and entanglement,"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 8,"candidatesTokenCount": 22,"totalTokenCount": 30,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 8}],"serviceTier": "standard"},"modelVersion": "gemini-3-flash-preview","responseId": "wEUBauTUFcHD-8YPzcWsoAY"}

data: {"candidates": [{"content": {"parts": [{"text": " to process information in ways classical computers cannot. While traditional computers use bits representing either a 0 or a 1, quantum computers use qubits"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 8,"candidatesTokenCount": 50,"totalTokenCount": 58,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 8}],"serviceTier": "standard"},"modelVersion": "gemini-3-flash-preview","responseId": "wEUBauTUFcHD-8YPzcWsoAY"}

