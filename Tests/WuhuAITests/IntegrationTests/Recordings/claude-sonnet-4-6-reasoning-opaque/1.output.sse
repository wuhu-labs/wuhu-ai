event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":"## Finding the Original Price\n\n### Setting Up the Problem\nA 20% discount means you **pay 80%"}    }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":"** of the original price.\n\n$$\\text{Original Price} \\times 0.80 = \\$25$$\n\n### Solving for the Original Price\n\n$$\\text{Original Price}"} }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":" = \\frac{\\$25}{0.80}$$\n\n$$\\text{Original Price} = \\$31.25$$\n\n### Verification ✓\n-"}    }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":" Original price: **$31.25**\n- 20% discount: $31.25 × 0.20 = $6.25\n- Final"}    }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":" price: $31.25 − $6.25 = **$25.00** ✓\n\nThe original price was **$31.25**.\n\n---\n**"}           }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":"Common mistake to avoid:** Don't add 20% back to $25 ($"}              }

event: content_block_delta
data: {"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":"25 × 1.20 = $30). That would give the wrong answer because the 20% should"}    }

event: content_block_delta
