data: {"candidates": [{"content": {"parts": [{"text": ".\n\n2.  **Set up the equation:**\n    We know that $25 is 80% of the original price. Let 'x' represent the original price.\n    So, 80% of x"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 27,"candidatesTokenCount": 108,"totalTokenCount": 626,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 27}],"thoughtsTokenCount": 491,"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "puz_acDSH9CN_PUPrq6W2A0"}

data: {"candidates": [{"content": {"parts": [{"text": " = $25\n    Or, as a decimal: 0.80 * x = $25\n\n3.  **Solve for x:**\n    To find x, divide $25 by 0.80"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 27,"candidatesTokenCount": 156,"totalTokenCount": 674,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 27}],"thoughtsTokenCount": 491,"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "puz_acDSH9CN_PUPrq6W2A0"}

