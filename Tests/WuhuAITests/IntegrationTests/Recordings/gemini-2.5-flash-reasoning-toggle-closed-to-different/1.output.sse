data: {"candidates": [{"content": {"parts": [{"text": " the principles of quantum mechanics—superposition and entanglement—to process information in fundamentally"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 8,"candidatesTokenCount": 19,"totalTokenCount": 27,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 8}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "puz_aZS5IYG2_uMPlqz60A8"}

data: {"candidates": [{"content": {"parts": [{"text": " new ways compared to classical computers. Instead of bits representing 0 or 1, quantum computers use \"qubits\" that can be both 0 and 1 simultaneously (superposition) and become interconnected (entanglement), allowing them to explore"}],"role": "model"},"index": 0}],"usageMetadata": {"promptTokenCount": 8,"candidatesTokenCount": 68,"totalTokenCount": 76,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 8}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "puz_aZS5IYG2_uMPlqz60A8"}

data: {"candidates": [{"content": {"parts": [{"text": " and process a vast number of possibilities at once. This enables them to solve certain complex computational problems intractable for even the most powerful supercomputers, with potential applications in fields like drug discovery, materials science, cryptography, and artificial intelligence."}],"role": "model"},"finishReason": "STOP","index": 0}],"usageMetadata": {"promptTokenCount": 8,"candidatesTokenCount": 114,"totalTokenCount": 122,"promptTokensDetails": [{"modality": "TEXT","tokenCount": 8}],"serviceTier": "standard"},"modelVersion": "gemini-2.5-flash","responseId": "puz_aZS5IYG2_uMPlqz60A8"}

